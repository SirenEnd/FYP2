generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── BRANCH ───────────────────────────────────
model Branch {
  id          Int         @id @default(autoincrement())
  name        String      @unique
  address     String?
  latitude    Float?
  longitude   Float?
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  employees   Employee[]
  timetables  Timetable[]
  attendances Attendance[]
}

// ─── DEPARTMENT ───────────────────────────────
model Department {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  createdAt DateTime   @default(now())
  employees Employee[]
}

// ─── EMPLOYEE ─────────────────────────────────
model Employee {
  id           Int        @id @default(autoincrement())
  employeeId   String     @unique
  name         String
  email        String     @unique
  password     String
  phone        String?
  role         Role       @default(STAFF)
  position     String?
  salary       Float      @default(0)
  departmentId Int
  department   Department @relation(fields: [departmentId], references: [id])
  branchId     Int?
  branch       Branch?    @relation(fields: [branchId], references: [id])
  isActive     Boolean    @default(true)
  joinDate     DateTime   @default(now())
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  attendances   Attendance[]
  leaveRequests LeaveRequest[]
  payrolls      Payroll[]
  performances  Performance[]
  timetableSlots TimetableSlot[]
}

enum Role {
  STAFF
  SUPERVISOR
  ADMIN
}

// ─── ATTENDANCE ───────────────────────────────
model Attendance {
  id         Int              @id @default(autoincrement())
  employeeId Int
  employee   Employee         @relation(fields: [employeeId], references: [id])
  clockIn    DateTime
  clockOut   DateTime?
  breakStart DateTime?
  breakEnd   DateTime?
  totalHours Float?
  status     AttendanceStatus @default(PRESENT)
  date       DateTime         @default(now())
  branchId   Int?
  branch     Branch?          @relation(fields: [branchId], references: [id])
  latitude   Float?
  longitude  Float?
  createdAt  DateTime         @default(now())
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  ON_LEAVE
}

// ─── TIMETABLE ────────────────────────────────
model Timetable {
  id            Int             @id @default(autoincrement())
  branchId      Int
  branch        Branch          @relation(fields: [branchId], references: [id])
  name          String
  effectiveFrom DateTime
  effectiveTo   DateTime?
  isActive      Boolean         @default(true)
  createdBy     Int
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  slots         TimetableSlot[]
}

// ─── TIMETABLE SLOT ───────────────────────────
model TimetableSlot {
  id          Int       @id @default(autoincrement())
  timetableId Int
  timetable   Timetable @relation(fields: [timetableId], references: [id])
  employeeId  Int
  employee    Employee  @relation(fields: [employeeId], references: [id])
  dayOfWeek   Int       // 0=Mon, 1=Tue, 2=Wed, 3=Thu, 4=Fri, 5=Sat, 6=Sun
  startHour   Int       // 7 = 07:00, 23 = 23:00
  endHour     Int       // startHour + 1
  station     String?
  createdAt   DateTime  @default(now())

  @@unique([timetableId, dayOfWeek, startHour, employeeId])
}

// ─── LEAVE REQUEST ────────────────────────────
model LeaveRequest {
  id           Int         @id @default(autoincrement())
  employeeId   Int
  employee     Employee    @relation(fields: [employeeId], references: [id])
  leaveType    LeaveType
  startDate    DateTime
  endDate      DateTime
  totalDays    Int
  reason       String?
  status       LeaveStatus @default(PENDING)
  reviewedBy   Int?
  reviewedAt   DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

enum LeaveType {
  ANNUAL
  MEDICAL
  EMERGENCY
  UNPAID
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

model Payroll {
  id               Int           @id @default(autoincrement())
  employeeId       Int
  employee         Employee      @relation(fields: [employeeId], references: [id])
  cycleStart       DateTime
  cycleEnd         DateTime
  basicSalary      Float
  overtimeHours    Float         @default(0)
  overtimePay      Float         @default(0)
  epfDeduction     Float         @default(0)
  socsoDeduction   Float         @default(0)
  grossSalary      Float
  netSalary        Float
  advanceDeduction Float         @default(0)
  status           PayrollStatus @default(PENDING)
  paidAt           DateTime?
  createdAt        DateTime      @default(now())
  advances         SalaryAdvance[]
}

model SalaryAdvance {
  id                Int           @id @default(autoincrement())
  employeeId        Int
  employee          Employee      @relation(fields: [employeeId], references: [id])
  amount            Float
  reason            String?
  status            AdvanceStatus @default(PENDING)
  reviewedBy        Int?
  reviewedAt        DateTime?
  requestedAt       DateTime      @default(now())
  deductedPayrollId Int?
  deductedPayroll   Payroll?      @relation(fields: [deductedPayrollId], references: [id])
}

enum AdvanceStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── PERFORMANCE ──────────────────────────────
model Performance {
  id         Int      @id @default(autoincrement())
  employeeId Int
  employee   Employee @relation(fields: [employeeId], references: [id])
  reviewerId Int
  score      Float
  comments   String?
  quarter    Int
  year       Int
  createdAt  DateTime @default(now())
}